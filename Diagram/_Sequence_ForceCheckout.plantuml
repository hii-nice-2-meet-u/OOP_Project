@startuml UC14_ForceCheckout
skinparam style strictuml
skinparam sequenceMessageAlign center
skinparam defaultFontSize 11
skinparam MaxMessageSize 150

title Sequence Diagram: UC14 — Force Checkout (Administrative Overstay Resolution)

actor "Staff" as staff
participant ":CafeSystem" as system
participant "branch:CafeBranch" as branch
participant "table:Table" as table
participant "session:PlaySession" as session

== Phase 1: Detection via Check-in Attempt ==

staff -> system : check_in_reserved(res_id, cust_id)
activate system
    system -> table : status
    system -> branch : find_play_session_by_id(table_id)
    system -> session : check_time_up(now)
    activate session
    session --> system : isExpired (True)
    deactivate session
    
    system -> system : get_active_bill(session_id)
    system --> staff : ValueError("FORCE CHECKOUT REQUIRED...")
deactivate system

== Phase 2: Perform Auto Force Checkout ==

staff -> system : auto_force_checkout(session_id, staff_id, method, ...)
activate system
    system -> system : find_person_by_id(staff_id)
    system -> system : find_play_session_by_id(session_id)
    
    group Smart Cleanup [Loop for borrowed games]
        system -> system : return_board_game(session_id, game_id)
        activate system
        system --> system : success
        deactivate system
    end
    
    group Smart Cleanup [Loop for pending orders]
        system -> system : update_order_cancel(session_id, order_id)
        activate system
        system --> system : success
        deactivate system
    end
    
    system -> system : check_out(session_id, method, ...)
    activate system
        system -> branch : end_play_session(session_id, now)
        activate branch
            branch -> branch : remove_play_session(session_id)
            branch -> branch : add_to_history(session)
        deactivate branch
        
        system -> table : set_status(AVAILABLE)
        system --> system : (payment, total)
    deactivate system
    
    system --> staff : return (payment, total)
deactivate system

@enduml
