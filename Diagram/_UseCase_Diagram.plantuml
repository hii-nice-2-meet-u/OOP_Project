@startuml
left to right direction
skinparam packageStyle rectangle

title Board Game Cafe System Use Case Diagram

' -------------------------------
' Actors Definition
' -------------------------------
actor "Member" as member
actor "Walk-in Customer" as guest
actor "Staff" as staff
actor "Manager" as manager
actor "Owner" as owner
actor "System Process" as systemProc << (S,#ADF) automated >>
actor "Payment Gateway\n(Bank / Online)" as payGateway

' Generalization: Manager IS-A Staff
manager -up-|> staff

' -------------------------------
' System Boundary
' -------------------------------
rectangle "Board Game Cafe System" {

    ' === REGISTRATION ===
    usecase "Register as Member" as UC_Register #LightYellow
    usecase "Assign Member ID & Tier" as UC_AssignID #LightYellow
    UC_Register ..> UC_AssignID : <<include>>

    ' === RESERVATION ===
    usecase "Make Reservation" as UC_MakeResv #LightBlue
    usecase "Validate Booking Rules" as UC_ValidateRules #LightYellow
    usecase "Check Table Availability" as UC_CheckTable #LightYellow
    usecase "Assign Table to Reservation" as UC_AssignTable #LightYellow
    UC_MakeResv ..> UC_ValidateRules : <<include>>
    UC_MakeResv ..> UC_CheckTable : <<include>>
    UC_CheckTable ..> UC_AssignTable : <<include>>

    usecase "Cancel Reservation" as UC_CancelResv #LightBlue
    usecase "Check Cancellation Window\n(1-Day Refund Rule)" as UC_CheckCancelWindow #LightYellow
    usecase "Update Status to CANCELLED" as UC_SetCancelled #LightYellow
    UC_CancelResv ..> UC_CheckCancelWindow : <<include>>
    UC_CancelResv ..> UC_SetCancelled : <<include>>

    ' === CHECK-IN ===
    usecase "Walk-in Check-in" as UC_WalkIn #LightBlue
    usecase "Open Play Session\n& Assign Table" as UC_OpenSession #LightYellow
    usecase "Create Walk-in Profile" as UC_CreateWalkIn #LightYellow
    UC_WalkIn ..> UC_CreateWalkIn : <<include>>
    UC_WalkIn ..> UC_OpenSession : <<include>>

    usecase "Check-in via Reservation" as UC_CheckInResv #LightBlue
    usecase "Verify Reservation\n& Time Window" as UC_VerifyResv #LightYellow
    usecase "Check No-Show Threshold\n(15-Minute Rule)" as UC_CheckNoShow #LightYellow
    usecase "Mark Reservation COMPLETED" as UC_MarkComplete #LightYellow
    UC_CheckInResv ..> UC_VerifyResv : <<include>>
    UC_CheckInResv ..> UC_OpenSession : <<include>>
    UC_CheckInResv ..> UC_MarkComplete : <<include>>
    UC_CheckInResv ..> UC_CheckNoShow : <<include>>
    systemProc --> UC_CheckNoShow : periodic check

    usecase "Join Existing Session" as UC_JoinSession #LightYellow
    usecase "Check Table Capacity" as UC_CheckCap #LightYellow
    usecase "Validate Player Status\n(Active Session Check)" as UC_ValidateActivePlayer #LightYellow
    UC_JoinSession ..> UC_CheckCap : <<include>>
    UC_JoinSession ..> UC_ValidateActivePlayer : <<include>>

    usecase "Check Session Time Limit" as UC_CheckTimeLimit #LightYellow

    ' === IN-SESSION ===
    usecase "Order Food & Drinks" as UC_OrderFood #LightBlue
    usecase "Record Order (PENDING)" as UC_RecordOrder #LightYellow
    UC_OrderFood ..> UC_RecordOrder : <<include>>
    UC_OrderFood ..> UC_CheckTimeLimit : <<include>>

    usecase "Serve & Update Order" as UC_ServeOrder #LightYellow
    usecase "Update Order Status" as UC_UpdateOrder #LightYellow
    UC_ServeOrder ..> UC_UpdateOrder : <<include>>

    usecase "Borrow Board Game" as UC_BorrowBG #LightBlue
    usecase "Check Game Availability" as UC_CheckBG #LightYellow
    usecase "Mark Game as IN-USE" as UC_MarkInUse #LightYellow
    UC_BorrowBG ..> UC_CheckBG : <<include>>
    UC_BorrowBG ..> UC_CheckTimeLimit : <<include>>
    UC_BorrowBG ..> UC_MarkInUse : <<include>>

    usecase "Return Board Game" as UC_ReturnBG #LightBlue
    usecase "Apply Damage Penalty" as UC_DamagePenalty #LightYellow
    usecase "Update Game Status" as UC_UpdateGameStatus #LightYellow
    UC_ReturnBG ..> UC_UpdateGameStatus : <<include>>
    UC_ReturnBG <.. UC_DamagePenalty : <<extend>>

    ' === CHECKOUT & BILLING ===
    usecase "Checkout & Process Payment" as UC_Checkout #LightBlue
    usecase "Verify Session State" as UC_VerifySession #LightYellow
    usecase "Calculate Table Fee" as UC_CalcFee #LightYellow
    usecase "Apply Member Discount" as UC_ApplyDiscount #LightYellow
    usecase "Process External Payment" as UC_ProcessPay #LightYellow
    usecase "Update Member Tier" as UC_UpdateTier #LightYellow
    UC_Checkout ..> UC_VerifySession : <<include>>
    UC_Checkout ..> UC_CalcFee : <<include>>
    UC_Checkout ..> UC_ProcessPay : <<include>>
    UC_Checkout ..> UC_UpdateTier : <<include>>
    UC_Checkout <.. UC_ApplyDiscount : <<extend>>
    UC_ProcessPay ..> payGateway : <<include>>

    usecase "Preview Active Bill" as UC_GetActiveBill #LightYellow
    usecase "View Bill History" as UC_ViewBill #LightYellow

    usecase "Force Checkout\n(Overstay Resolution)" as UC_ForceCheckout #LightBlue
    UC_ForceCheckout ..> UC_Checkout : <<include>>
}

' -------------------------------
' Management Use Cases
' -------------------------------
rectangle "Management Dashboard" {
    usecase "Manage Menu\n(Add / Update / Remove)" as UC_ManageMenu #LightYellow
    usecase "Manage Board Games\n(Add / Update / Remove / Maintenance)" as UC_ManageBG #LightYellow
    usecase "Manage Tables\n(Add / Update Status)" as UC_ManageTables #LightYellow
    usecase "Manage Employees\n(Staff / Manager)" as UC_ManageStaff #LightYellow
    usecase "Manage Cafe Branches\n(CRUD)" as UC_ManageBranches #LightYellow
    usecase "Manage Management\n(Owner / Manager)" as UC_ManageMgmt #LightYellow
    usecase "View Bill History " as UC_ViewBillMgr #LightYellow
}

' -------------------------------
' Actor Associations
' -------------------------------

' --- Member ---
member --> UC_Register
member --> UC_MakeResv
member --> UC_CancelResv
member --> UC_CheckInResv
member --> UC_JoinSession
member --> UC_BorrowBG
member --> UC_ReturnBG
member --> UC_OrderFood
member --> UC_Checkout
member --> UC_ViewBill


' --- Walk-in Guest ---
guest --> UC_WalkIn
guest --> UC_JoinSession
guest --> UC_BorrowBG
guest --> UC_ReturnBG
guest --> UC_OrderFood
guest --> UC_Checkout

' --- Staff (Manager inherits via Generalization) ---
staff --> UC_WalkIn
staff --> UC_CheckInResv
staff --> UC_ForceCheckout
staff --> UC_ServeOrder
staff --> UC_GetActiveBill

' --- Manager + Owner (Management Actions) ---
manager --> UC_ManageMenu
manager --> UC_ManageBG
manager --> UC_ManageTables
manager --> UC_ManageStaff
manager --> UC_ViewBillMgr

' --- Member can also preview their own running bill ---
member --> UC_GetActiveBill

' --- Owner (Full Authority) ---
owner --> UC_ManageMenu
owner --> UC_ManageBG
owner --> UC_ManageTables
owner --> UC_ManageStaff
owner --> UC_ManageBranches : CRUD
owner --> UC_ManageMgmt : Create/Update/Remove
owner --> UC_ViewBillMgr

@enduml