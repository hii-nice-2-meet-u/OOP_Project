@startuml
left to right direction
skinparam packageStyle rectangle

actor Owner
actor Manager
actor Staff
actor Customer
actor "Payment Gateway" as Bank

rectangle "Board Game Cafe System" {

' ===============================
' MEMBER & AUTH
' ===============================

usecase "Register Member" as UC_Register
usecase "Login" as UC_Login
usecase "View Menu & Board Games" as UC_ViewCatalog

Customer --> UC_Register
Customer --> UC_Login
Customer --> UC_ViewCatalog


' ===============================
' RESERVATION SYSTEM
' ===============================

usecase "Create Reservation" as UC_CreateRes
usecase "Update Reservation Status" as UC_UpdateRes
usecase "Cancel Reservation" as UC_CancelRes
usecase "Check Table Availability" as UC_CheckTable

Customer --> UC_CreateRes
Customer --> UC_CancelRes

UC_CreateRes --> UC_CheckTable : <<include>>
UC_CancelRes --> UC_UpdateRes : <<include>>


' ===============================
' PLAY SESSION
' ===============================

usecase "Open Play Session" as UC_OpenSession
usecase "Add Players to Session" as UC_AddPlayer
usecase "End Play Session" as UC_EndSession

Staff --> UC_OpenSession
Staff --> UC_EndSession

UC_OpenSession --> UC_AddPlayer : <<include>>


' ===============================
' BOARD GAME MANAGEMENT
' ===============================

usecase "Borrow Board Game" as UC_BorrowGame
usecase "Return Board Game" as UC_ReturnGame
usecase "Update Game Status" as UC_UpdateGame

Customer --> UC_BorrowGame
Customer --> UC_ReturnGame

Staff --> UC_UpdateGame

UC_BorrowGame --> UC_UpdateGame : <<include>>
UC_ReturnGame --> UC_UpdateGame : <<include>>


' ===============================
' FOOD & DRINK ORDER
' ===============================

usecase "Create Order" as UC_CreateOrder
usecase "Add Menu Item to Order" as UC_AddItem
usecase "Cancel Order" as UC_CancelOrder
usecase "Serve Order" as UC_ServeOrder

Customer --> UC_CreateOrder
Staff --> UC_AddItem
Staff --> UC_ServeOrder

UC_CreateOrder --> UC_AddItem : <<include>>


' ===============================
' PAYMENT
' ===============================

usecase "Process Payment" as UC_Payment
usecase "Select Payment Method" as UC_SelectMethod
usecase "Verify Payment" as UC_VerifyPay

Customer --> UC_Payment
Staff --> UC_Payment

UC_Payment --> UC_SelectMethod : <<include>>
UC_SelectMethod --> UC_VerifyPay : <<include>>

Bank --> UC_VerifyPay


' ===============================
' MENU & INVENTORY
' ===============================

usecase "Manage Menu" as UC_ManageMenu
usecase "Add Food Item" as UC_AddFood
usecase "Add Drink Item" as UC_AddDrink
usecase "Remove Menu Item" as UC_RemoveMenu

Manager --> UC_ManageMenu

UC_ManageMenu --> UC_AddFood : <<include>>
UC_ManageMenu --> UC_AddDrink : <<include>>
UC_ManageMenu --> UC_RemoveMenu : <<include>>


' ===============================
' BRANCH MANAGEMENT
' ===============================

usecase "Create Cafe Branch" as UC_CreateBranch
usecase "Add Table to Branch" as UC_AddTable
usecase "Add Board Game to Branch" as UC_AddGame

Owner --> UC_CreateBranch
Manager --> UC_AddTable
Manager --> UC_AddGame


' ===============================
' STAFF MANAGEMENT
' ===============================

usecase "Add Staff" as UC_AddStaff
usecase "Assign Manager to Branch" as UC_AssignManager
usecase "View Reports" as UC_Report

Owner --> UC_AddStaff
Owner --> UC_AssignManager
Owner --> UC_Report
Manager --> UC_Report

}

@enduml